JWT_SECRET=change-this-long-random-value
DATABASE_URL=sqlite:///./data/medicine.db
AI_PROVIDER=local_medgemma
AI_SERVICE_URL=
AI_ALLOW_MOCK=false
AI_CONFIDENCE_THRESHOLD=0.70
AI_MODEL_VERSION=google/medgemma-1.5-4b-it-local
AI_DATASET_VERSION=local-unvalidated
LOCAL_MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
LOCAL_MEDGEMMA_MODEL_PATH=../models/medgemma-1.5-4b-it
LOCAL_MEDGEMMA_LOCAL_FILES_ONLY=true
LOCAL_MEDGEMMA_DEVICE=auto
LOCAL_MEDGEMMA_DTYPE=auto
LOCAL_MEDGEMMA_LOAD_IN_4BIT=true
LOCAL_MEDGEMMA_MAX_NEW_TOKENS=350
LOCAL_MEDGEMMA_MAX_IMAGE_SIDE=1600
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://aimedicine.vercel.app,https://medicine-local-medgemma.vercel.app

# MedAI chat assistant. Never expose this key through VITE_* variables.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=45
