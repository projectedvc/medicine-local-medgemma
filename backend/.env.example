JWT_SECRET=change-this-long-random-value
DATABASE_URL=sqlite:///./data/medicine.db
MAX_UPLOAD_MB=20
AI_PROVIDER=external
AI_SERVICE_URL=http://127.0.0.1:8005/generate
AI_SERVICE_API_KEY=
AI_SERVICE_CF_ACCESS_CLIENT_ID=
AI_SERVICE_CF_ACCESS_CLIENT_SECRET=
AI_ALLOW_MOCK=false
AI_CONFIDENCE_THRESHOLD=0.70
AI_MODEL_VERSION=google/medgemma-4b-it
AI_DATASET_VERSION=local-unvalidated
LOCAL_MEDGEMMA_MODEL_ID=google/medgemma-4b-it
LOCAL_MEDGEMMA_MODEL_PATH=../models/medgemma-4b-it
LOCAL_MEDGEMMA_LOCAL_FILES_ONLY=true
LOCAL_MEDGEMMA_DEVICE=auto
LOCAL_MEDGEMMA_DTYPE=auto
LOCAL_MEDGEMMA_LOAD_IN_4BIT=true
LOCAL_MEDGEMMA_MAX_NEW_TOKENS=350
LOCAL_MEDGEMMA_MAX_IMAGE_SIDE=1600
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://aimedicine.vercel.app
