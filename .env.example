JWT_SECRET=change-this-long-random-value
# Jupiter AI endpoint. For the shown ngrok notebook API use:
# AI_SERVICE_URL=https://shiny-net-slimy.ngrok-free.dev/generate
AI_SERVICE_URL=
AI_ALLOW_MOCK=false
AI_CONFIDENCE_THRESHOLD=0.70
AI_MODEL_VERSION=jupiter-or-demo-v1
AI_DATASET_VERSION=not-validated-demo
TRANSLATION_PROVIDER=google
TRANSLATION_TIMEOUT_SECONDS=8
TRANSLATION_MAX_CHARS=4500
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aimedicine.vercel.app,https://medicine-local-medgemma.vercel.app

# MedAI chat assistant. Keep the key on the backend only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=45
# Used only by local frontend dev. Production uses /api from vercel.json.
VITE_API_URL=http://127.0.0.1:8000
