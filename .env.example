JWT_SECRET=change-this-long-random-value
# External GPU endpoint. Keep secrets server-side; never prefix them with VITE_.
AI_PROVIDER=external
AI_SERVICE_URL=https://gpu-api.example.com/generate
AI_SERVICE_API_KEY=
AI_SERVICE_CF_ACCESS_CLIENT_ID=
AI_SERVICE_CF_ACCESS_CLIENT_SECRET=
AI_ALLOW_MOCK=false
AI_CONFIDENCE_THRESHOLD=0.70
AI_MODEL_VERSION=google/medgemma-4b-it
AI_DATASET_VERSION=local-unvalidated
TRANSLATION_PROVIDER=google
TRANSLATION_TIMEOUT_SECONDS=8
TRANSLATION_MAX_CHARS=4500
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aimedicine.vercel.app
# Used at Vite build time in both development and production.
VITE_API_URL=http://127.0.0.1:8000
